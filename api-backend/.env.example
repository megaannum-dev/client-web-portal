DATABASE_URL=mysql+pymysql://portal:portalsecret@localhost:3306/portal
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://kilt-backlight-crummiest.ngrok-free.dev
# docker-compose mounts firebase-client-web-portal.json and uses these defaults:
FIREBASE_PROJECT_ID=client-web-portal-2026
FIREBASE_CREDENTIALS_PATH=/secrets/firebase.json
# Or paste JSON for FIREBASE_SERVICE_ACCOUNT_JSON (overrides path when set).
FIREBASE_AUTH_DISABLED=false
