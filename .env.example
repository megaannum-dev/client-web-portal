# Root env for docker-compose (copy to .env and fill Firebase for production auth)
MARIADB_ROOT_PASSWORD=rootsecret
MARIADB_DATABASE=portal
MARIADB_USER=portal
MARIADB_PASSWORD=portalsecret
API_PORT=8000
ADMIN_PORT=3001
CLIENT_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_DISABLED=false
# Set to true only for temporary local smoke tests (no Firebase token verification)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
